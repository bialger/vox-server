# Required on the server: image from GitHub Container Registry (CI sets this per deploy).
# Example: VOX_IMAGE=ghcr.io/your-org/vox-server:abc123def...
# VOX_IMAGE=

# Required. Secret for HMAC of session tokens (changing it invalidates all sessions).
# VOX_SESSION_PEPPER=

# Optional. If set, enables /v1/admin/* with header X-Admin-Token.
# VOX_ADMIN_TOKEN=

# Optional. Same effect as --config (entrypoint passes --config when /etc/vox.conf exists).
# VOX_CONFIG_FILE=/etc/vox.conf

# --- SDUI (EULA + update) ---
#
# SDUI settings live in `deploy/vox.conf` (key=value). This .env file is only for Docker/entrypoint env vars.
# You typically do NOT set SDUI values here; set them in vox.conf and mount the EULA text file into the container.
#
# Example vox.conf keys (put these into deploy/vox.conf, not here):
#   sdui_repo_url = https://github.com/bialger/VoxMessenger
#   sdui_android_store_url = <later: Play Store url>
#   sdui_eula_path = /etc/vox/eula.txt
#   sdui_eula_version = 2026-04-23
#   sdui_latest_client_version_code = 123
